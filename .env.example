# =============================================================================
# Finance Specialist AI - Environment Configuration
# =============================================================================

# API Keys - Foundation Models
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Financial Data APIs
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
FMP_API_KEY=your_financial_modeling_prep_key_here
FRED_API_KEY=your_fred_api_key_here
POLYGON_API_KEY=your_polygon_api_key_here
QUANDL_API_KEY=your_quandl_api_key_here
IEX_API_KEY=your_iex_cloud_key_here

# News and Market Data APIs
NEWS_API_KEY=your_news_api_key_here
FINNHUB_API_KEY=your_finnhub_key_here
MARKETSTACK_API_KEY=your_marketstack_key_here

# Vector Database Configuration
# Option 1: Chroma (Local)
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Option 2: Pinecone (Cloud)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here
PINECONE_INDEX_NAME=finance-specialist-ai

# Option 3: Weaviate (Cloud/Local)
WEAVIATE_URL=your_weaviate_url_here
WEAVIATE_API_KEY=your_weaviate_api_key_here

# Database Configuration
# PostgreSQL (Production)
DATABASE_URL=postgresql://user:password@localhost:5432/finance_specialist_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_specialist_db
DB_USER=finance_user
DB_PASSWORD=your_db_password_here

# Redis (Caching)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password_here

# Application Configuration
APP_NAME=Finance Specialist AI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security Configuration
SECRET_KEY=your_secret_key_here_make_it_very_long_and_random
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# Model Configuration
DEFAULT_MODEL=gpt-4-turbo-preview
FALLBACK_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-ada-002
MODEL_TEMPERATURE=0.1
MAX_TOKENS=4000

# Financial Data Configuration
DEFAULT_MARKET=US
DEFAULT_CURRENCY=USD
MARKET_HOURS_TIMEZONE=America/New_York
DATA_CACHE_TTL_SECONDS=300

# Memory and Context Configuration
MAX_CONVERSATION_HISTORY=50
VECTOR_SEARCH_K=10
SIMILARITY_THRESHOLD=0.7

# Monitoring and Observability
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=finance-specialist-ai
ENABLE_TRACING=true

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# File Storage
UPLOAD_DIRECTORY=./data/uploads
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,docx,xlsx,csv,txt

# Email Configuration (for alerts/notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password_here
FROM_EMAIL=noreply@finance-specialist-ai.com

# Compliance and Audit
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=INFO
DATA_RETENTION_DAYS=365

# Feature Flags
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_PORTFOLIO_OPTIMIZATION=true
ENABLE_RISK_ASSESSMENT=true
ENABLE_NEWS_SENTIMENT=true
ENABLE_TECHNICAL_ANALYSIS=true

# External Integrations
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Development/Testing
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/test_finance_db
MOCK_API_CALLS=false
ENABLE_DEBUG_TOOLBAR=false